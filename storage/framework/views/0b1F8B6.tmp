    <style>
        [data-flux-sidebar] {
            transition: width 300ms cubic-bezier(0.4, 0, 0.2, 1),
                        max-width 300ms cubic-bezier(0.4, 0, 0.2, 1),
                        min-width 300ms cubic-bezier(0.4, 0, 0.2, 1);
